{
    "manifest_version": 3,
    "name": "Bookmark Brain",
    "version": "1.0",
    "description": "Semantic search for your browsing history",
    "permissions": ["activeTab", "storage"],
    "host_permissions": ["<all_urls>"],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}